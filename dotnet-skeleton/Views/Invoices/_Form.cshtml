@model InvoiceFormPageViewModel

<div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

<div class="form-group">
    <label asp-for="Form.Number"></label>
    <input asp-for="Form.Number" />
    <span asp-validation-for="Form.Number" class="error"></span>
</div>

<div class="form-group">
    <label asp-for="Form.CustomerId"></label>
    <select asp-for="Form.CustomerId" asp-items="Model.Customers">
        <option value="">— wybierz —</option>
    </select>
    <span asp-validation-for="Form.CustomerId" class="error"></span>
</div>

<div class="form-group">
    <label asp-for="Form.Amount"></label>
    <input asp-for="Form.Amount" type="number" step="0.01" min="0.01" />
    <span asp-validation-for="Form.Amount" class="error"></span>
</div>

<div class="form-group">
    <label asp-for="Form.Status"></label>
    <select asp-for="Form.Status" asp-items="@(new SelectList(Model.Statuses))"></select>
    <span asp-validation-for="Form.Status" class="error"></span>
</div>

<div class="form-group">
    <label asp-for="Form.IssuedAt"></label>
    <input asp-for="Form.IssuedAt" type="date" />
    <span asp-validation-for="Form.IssuedAt" class="error"></span>
</div>

<div class="form-group">
    <label asp-for="Form.DueAt"></label>
    <input asp-for="Form.DueAt" type="date" />
    <span asp-validation-for="Form.DueAt" class="error"></span>
</div>
