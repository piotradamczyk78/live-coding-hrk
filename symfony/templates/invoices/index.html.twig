{% extends 'base.html.twig' %}

{% block title %}Faktury - Symfony{% endblock %}

{% block stylesheets %}
    {{ include('invoices/_styles.html.twig') }}
{% endblock %}

{% block body %}
    <div class="header">
        <h1>Faktury</h1>
        <a href="{{ path('invoices_new') }}" class="btn btn-primary">+ Nowa faktura</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% if invoices is empty %}
        <p class="empty">Brak faktur w bazie danych.</p>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Numer</th>
                    <th>Klient</th>
                    <th>Kwota</th>
                    <th>Status</th>
                    <th>Wystawiona</th>
                    <th>Termin płatności</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                {% for invoice in invoices %}
                    <tr>
                        <td>{{ invoice.id }}</td>
                        <td>{{ invoice.number }}</td>
                        <td>{{ invoice.customer ? invoice.customer.name : '—' }}</td>
                        <td class="amount">{{ invoice.amount|number_format(2, ',', ' ') }} PLN</td>
                        <td>
                            <span class="status status-{{ invoice.status }}">
                                {{ invoice.status }}
                            </span>
                        </td>
                        <td>{{ invoice.issuedAt ? invoice.issuedAt|date('Y-m-d') : '—' }}</td>
                        <td>{{ invoice.dueAt ? invoice.dueAt|date('Y-m-d') : '—' }}</td>
                        <td>
                            <div class="actions">
                                <a href="{{ path('invoices_edit', {id: invoice.id}) }}" class="btn btn-secondary btn-sm">Edytuj</a>
                                <form method="post" action="{{ path('invoices_delete', {id: invoice.id}) }}"
                                      onsubmit="return confirm('Czy na pewno usunąć fakturę {{ invoice.number }}?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ invoice.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm">Usuń</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
